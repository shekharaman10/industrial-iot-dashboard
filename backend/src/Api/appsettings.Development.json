{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Mqtt": {
    "Host": "localhost",
    "Port": 1883
  },
  "InfluxDb": {
    "Url":    "http://localhost:8086",
    "Token":  "dev-token-change-in-production",
    "Org":    "iot-org",
    "Bucket": "sensor-readings"
  },
  "Postgres": {
    "ConnectionString": "Host=localhost;Port=5432;Database=iotdb;Username=iot;Password=iot_secret;Include Error Detail=true"
  },
  "AllowedOrigins": ["http://localhost:3000", "http://localhost:5173"]
}
