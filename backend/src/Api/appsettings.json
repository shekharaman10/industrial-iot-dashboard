{
  "Mqtt": {
    "Host": "localhost",
    "Port": 1883,
    "ReconnectDelaySeconds": 5
  },
  "InfluxDb": {
    "Url": "http://localhost:8086",
    "Token": "dev-token-change-in-production",
    "Org": "iot-org",
    "Bucket": "sensor-readings"
  },
  "Postgres": {
    "ConnectionString": "Host=localhost;Port=5432;Database=iotdb;Username=iot;Password=iot_secret"
  },
  "AllowedOrigins": ["http://localhost:3000"],
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "MQTTnet": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
